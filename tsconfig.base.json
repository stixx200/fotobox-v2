{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "strict": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@fotobox/cameras": ["libs/cameras/src/index.ts"],
      "@fotobox/collage-maker": ["libs/collage-maker/src/index.ts"],
      "@fotobox/electron-window": ["libs/electron/window/src/index.ts"],
      "@fotobox/error": ["libs/error/src/index.ts"],
      "@fotobox/logging": ["libs/logging/src/index.ts"],
      "@fotobox/nest-app-service": ["libs/nest/app-service/src/index.ts"],
      "@fotobox/nest-cameras-api": ["libs/nest/cameras-api/src/index.ts"],
      "@fotobox/nest-collage-maker": ["libs/nest/collage-maker/src/index.ts"],
      "@fotobox/nest-graphql": ["libs/nest/graphql/src/index.ts"],
      "@fotobox/nest-logger": ["libs/nest/logger/src/index.ts"],
      "@fotobox/nest-printer-api": ["libs/nest/printer-api/src/index.ts"],
      "@fotobox/nest-settings": ["libs/nest/settings/src/index.ts"],
      "@fotobox/nest-photo-storage": ["libs/nest/photo-storage/src/index.ts"],
      "@fotobox/nest-share-api": ["libs/nest/share-api/src/index.ts"],
      "@fotobox/photo-storage": ["libs/photo-storage/src/index.ts"],
      "@fotobox/nest-api": ["libs/nest/api/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
