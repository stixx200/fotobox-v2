{
  "$schema": "../../../../../node_modules/nx-electron/src/validation/maker.schema.json",
  "appId": "de.se-voelk.fotobox",
  "productName": "Fotobox",
  "directories": {
    "buildResources": "apps/fotobox-electron/build",
    "output": "dist/packages"
  },
  "icon": "icon.png",
  "files": ["**/*", "!**/*.map"],
  "asar": true,
  "asarUnpack": ["**/node_modules/sharp/**/*", "**/node_modules/@img/**/*"],
  "extraFiles": [
    {
      "from": "scripts/windows/setup-kiosk.ps1",
      "to": "setup-kiosk.ps1"
    }
  ],
  "win": {
    "target": "msi",
    "defaultArch": "x64",
    "icon": "icon.ico"
  },
  "mac": {
    "icon": "icon.icns"
  },
  "msi": {
    "perMachine": false,
    "runAfterFinish": true
  }
}
