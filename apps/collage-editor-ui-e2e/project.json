{
  "name": "collage-editor-ui-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/collage-editor-ui-e2e/src",
  "implicitDependencies": [
    "collage-editor-ui"
  ],
  "tags": [
    "scope:client",
    "type:e2e",
    "platform:angular"
  ],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --config=apps/collage-editor-ui-e2e/playwright.config.ts"
      }
    },
    "e2e-ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright test --config=apps/collage-editor-ui-e2e/playwright.config.ts --ui"
      }
    },
    "e2e-install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright install chromium"
      }
    },
    "e2e-ci": {
      "executor": "nx:run-commands",
      "options": {
        "command": "playwright install --with-deps chromium && playwright test --config=apps/collage-editor-ui-e2e/playwright.config.ts"
      }
    }
  }
}
